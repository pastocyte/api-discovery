# Backstage instance root URL (no trailing slash)
BACKSTAGE_URL=https://backstage.example.com

# Bearer token for the Backstage Catalog API
BACKSTAGE_TOKEN=your-backstage-token-here

# Override only if using GitHub Enterprise or self-hosted GitLab
# GITHUB_BASE_URL=https://github.example.com
# GITLAB_BASE_URL=https://gitlab.example.com
